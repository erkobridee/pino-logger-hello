{
  "name": "pino-logger-hello",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "typeschek": "tsc",
    "log:trace:test": "LOG_LEVEL=trace npx tsx src/test-logger.ts",
    "log:debug:test": "LOG_LEVEL=debug npx tsx src/test-logger.ts",
    "log:info:test": "LOG_LEVEL=info npx tsx src/test-logger.ts",
    "log:warn:test": "LOG_LEVEL=warn npx tsx src/test-logger.ts",
    "log:error:test": "LOG_LEVEL=error npx tsx src/test-logger.ts",
    "log:fatal:test": "LOG_LEVEL=fatal npx tsx src/test-logger.ts",
    "start": "npx tsx src/test-logger.ts"
  },
  "devDependencies": {
    "@types/node": "25.9.4",
    "pino-pretty": "13.1.3",
    "tsx": "4.23.0",
    "typescript": "6.0.3"
  },
  "dependencies": {
    "pino": "10.3.1"
  }
}
